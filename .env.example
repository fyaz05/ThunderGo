# ThunderGo Configuration
# Copy this file to .env and fill in the REQUIRED fields.

## REQUIRED ──────────────────────────────────────────────────────────────────

# Telegram API credentials — https://my.telegram.org → API development tools
#   Type: integer, required
TG_API_ID=
#   Type: string, required
TG_API_HASH=

# Bot token — get from @BotFather
#   Type: string, required, format: NNNNNNNNNN:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TG_BOT_TOKEN=

# Private channel for file storage (starts with -100):
#   1. Create a private channel
#   2. Add your bot as admin (enable "Post Messages")
#   3. Forward a message from it to @userinfobot
#   4. Paste the ID here
#   Type: integer (negative), required, format: -100NNNNNNNNNN
TG_VAULT_CHANNEL_ID=

# Your Telegram user ID — get from @userinfobot. Gives you admin access.
#   Type: integer (positive), required
TG_OWNER_USER_ID=

# MongoDB connection string (Atlas free tier recommended):
#   mongodb+srv://user:pass@cluster.mongodb.net
#   Type: string, required, format: mongodb[s]+://user:pass@host[:port]/db
TG_MONGO_URI=

# Your bot's full public URL — scheme is auto-detected (http or https).
# If no port is in the URL, the listen port defaults to 443 (https) or 8080 (http).
# Override the listen port with TG_HTTP_PORT (see below) for reverse-proxy setups.
#   Example: https://my-bot.example.com
#   Type: string, required, format: https?://host[:port]
TG_URL=


## OPTIONAL: Speed ───────────────────────────────────────────────────────────

# Extra bot tokens for faster downloads. Create bots via @BotFather,
# add each as admin to your vault channel. Use contiguous numbering.
TG_EXTRA_BOTS1=
TG_EXTRA_BOTS2=
TG_EXTRA_BOTS3=

# Max simultaneous downloads per bot client.
#   Type: integer, default: 8, range: 1+
# Higher = more parallelism but more Telegram rate-limit risk.
TG_MAX_CONCURRENT_PER_CLIENT=8

# Concurrent download threads per stream.
#   Type: integer, default: 4, range: 1-8
# Set to 2-4 for 2-3x faster large-file downloads.
# Do NOT exceed 8 — Telegram per-session flood limits.
# Use 1 for high-concurrency gateways (many users, different files).
TG_STREAM_THREADS=4


## OPTIONAL: Access Control ──────────────────────────────────────────────────

# Private mode: only you + authorized users can use the bot
#   Type: boolean, default: false
TG_PRIVATE_MODE=false

# Require users to join a channel first (channel ID starting with -100)
#   Type: integer (negative), default: 0 (disabled), format: -100NNNNNNNNNN
TG_FORCE_SUB_CHANNEL_ID=

# Token activation: unauthorized users must activate via a link before using the bot.
# Owner and authorized users bypass this gate.
#   Type: boolean, default: false
TG_TOKEN_ENABLED=false
#   Type: integer, default: 24, range: 1+ (when TG_TOKEN_ENABLED=true)
TG_TOKEN_TTL_HOURS=24

# Channel auto-processing: auto-generate links for media posted in channels where bot is admin
#   Type: boolean, default: false
TG_CHANNEL_AUTO_PROCESS=false

# Banned channel IDs (comma-separated)
#   Type: comma-separated integers (negative), format: -100NNNNNNNNNN[,-100NNNNNNNNNN,...]
TG_BANNED_CHANNEL_IDS=


## OPTIONAL: Rate Limiting ───────────────────────────────────────────────────

# Max files per user per minute (0 = disabled). Owner + authorized users bypass.
#   Type: integer, default: 0, range: 0+
TG_RATE_LIMIT=0

# Global requests-per-second cap across ALL users (0 = disabled).
# Prevents Telegram FLOOD_WAITs when many users are active simultaneously.
# Allows short bursts (2x this value) then smooths to the configured rate.
# Owner + authorized users bypass.
#   Type: integer, default: 0, range: 0+
TG_GLOBAL_RPS=0


## OPTIONAL: URL Shortener ───────────────────────────────────────────────────

# Shorten links for non-authorized users. Owner + authorized always get full links.
#   Type: string, optional
TG_SHORTENER_API_KEY=
#   Type: string, optional, format: https://site.com
TG_SHORTENER_SITE=


## OPTIONAL: Network ─────────────────────────────────────────────────────────

# HTTP listen port. 0 = auto-derive from TG_URL (443 for https, 8080 for http,
# or the explicit port in the URL). Set to a specific port (e.g. 8080) when
# behind a reverse proxy that terminates TLS on 443 but forwards to a local port.
# If TG_HTTP_PORT and the URL port disagree, TG_HTTP_PORT wins for the listener
# while TG_URL stays as the public-facing URL used in generated file links.
#   Type: integer, default: 0, range: 0 or 1-65535
TG_HTTP_PORT=0

# Interface to listen on (default 0.0.0.0 = all interfaces).
# Use 127.0.0.1 to restrict to loopback (e.g. behind a reverse proxy).
#   Type: string, default: 0.0.0.0, format: valid IPv4/IPv6 address
TG_BIND_ADDRESS=0.0.0.0

# Self-ping interval in SECONDS to keep PaaS processes awake (0 = disabled).
#   Type: integer (seconds), default: 300, range: 0+
TG_KEEPALIVE_SECS=300


## OPTIONAL: Auto-Update (non-Docker only) ────────────────────────────────────

# Git repo URL for auto-updating on startup. When set, thunder.sh will
# clone/pull the repo and rebuild the binary before starting. Only works
# when Go + git are available (bare metal, Heroku buildpack, etc.).
# Docker users: update by restarting to pull the latest GHCR image.
#   Type: string, optional
UPSTREAM_REPO=
#   Type: string, default: main
UPSTREAM_BRANCH=main


## OPTIONAL: Storage & Logging ───────────────────────────────────────────────

# Auto-expire files N days after they were CONVERTED (ingested), regardless of
# access (0 = never expire). The actual Telegram vault message is NOT deleted.
#   Type: integer (days), default: 0, range: 0+
TG_FILE_TTL_DAYS=0

# Log level.
#   Type: string, default: info, allowed: debug | info | warn | error
TG_LOG_LEVEL=info

# Max files per /link N batch.
#   Type: integer, default: 50, range: 1+
TG_BATCH_CAP=50
